# kkr-hotel-assist — example environment for LOCAL development.
# Copy to `.env` and fill in real values. Do not commit the real `.env`.

# --- Mail provider (local = stub; no Mailgun needed) ---
# stub  → outbound emails go to an in-memory outbox (logged as outbound.stub.recorded);
#         inbound webhooks at /webhooks/stub/inbound need no signature.
# mailgun → real Mailgun (production).
KKR_MAIL_PROVIDER=stub
KKR_MAIL_DOMAIN=kkr-hotel.com

# --- Postgres (provided by `docker compose up`) ---
KKR_POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/kkr
KKR_LANGGRAPH_DSN=postgresql://postgres:postgres@localhost:5432/kkr

# --- Temporal (provided by `docker compose up`) ---
KKR_TEMPORAL_TARGET=localhost:7233
KKR_TEMPORAL_TASK_QUEUE=kkr-hotel

# --- Negotiation timing ---
KKR_HOTEL_REPLY_TIMEOUT_SECONDS=172800
KKR_FOLLOWUP_MAX_ATTEMPTS=2
KKR_EXTRACTION_CONFIDENCE_THRESHOLD=0.7

# --- LLM ---
# Format "<provider>:<model>". Bare name defaults to openai.
#   zai:glm-5.2 | openai:gpt-4o-mini | gpt-4o-mini
KKR_LLM_MODEL=zai:glm-5.2

# Z.AI / Zhipu GLM (OpenAI-compatible) — required when KKR_LLM_MODEL uses the "zai:" provider.
# Default base_url is the Coding Plan endpoint (billed against the subscription, not PaaS credits).
# Key: your key from open.bigmodel.cn.
KKR_ZAI_API_KEY=
KKR_ZAI_API_BASE=https://open.bigmodel.cn/api/coding/paas/v4

# OpenAI (when KKR_LLM_MODEL uses the openai provider / bare name).
# OPENAI_API_KEY=
