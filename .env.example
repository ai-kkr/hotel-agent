# kkr-hotel-assist — пример окружения для ЛОКАЛЬНОЙ разработки.
# Скопируйте в `.env` и заполните реальные значения. Не коммитьте реальный `.env`.
# Полный список настроек — src/config.py (префикс KKR_).

# --- Режим ---
# true — исходящие письма уходят гостю (user_email), а не отелю; удобно для отладки отправки.
KKR_IS_DEV=true

# --- PostgreSQL (поднимается через `docker compose up postgres`) ---
KKR_POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/kkr
# DSN для синхронного драйвера psycopg (используется langgraph PostgresSaver, при необходимости).
KKR_LANGGRAPH_DSN=postgresql://postgres:postgres@localhost:5432/kkr

# --- Telegram-бот ---
KKR_TELEGRAM_BOT_TOKEN=

# --- LLM ---
# Формат "<provider>:<model>". Bare-имя по умолчанию означает openai.
#   zai:glm-5.2 | openrouter:anthropic/claude-3.5-sonnet | openai:gpt-4o-mini | gpt-4o-mini
KKR_LLM_MODEL=zai:glm-5.2
# Z.AI / Zhipu GLM (OpenAI-compatible) — обязателен при KKR_LLM_MODEL=zai:...
# Дефолтный base_url — Coding Plan endpoint (списывается с подписки, не с PaaS-баланса).
KKR_ZAI_API_KEY=
KKR_ZAI_API_BASE=https://open.bigmodel.cn/api/coding/paas/v4
# OpenRouter (OpenAI-compatible агрегатор) — обязателен при KKR_LLM_MODEL=openrouter:...
# Имя модели включает вендорный префикс, как ожидает OpenRouter (anthropic/..., openai/...).
KKR_OPENROUTER_API_KEY=
KKR_OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# Reasoning/thinking effort для openrouter: xhigh|high|medium|low|minimal|none (default: minimal).
# OpenRouter мапит это на per-model настройки (для Gemini — thinkingLevel). none выключает совсем.
KKR_OPENROUTER_REASONING_EFFORT=minimal
# OpenAI (когда KKR_LLM_MODEL использует провайдер openai / bare-имя):
# OPENAI_API_KEY=

# --- Tavily (веб-поиск для агента: search_internet / extract_web_page) ---
KKR_TAVILY_API_KEY=

# --- Mailtrap (входящие + отправка). Один API-токен работает и для inbound-API, и для отправки. ---
KKR_MAILTRAP_API_KEY=
# Секрет для проверки подписи inbound-webhook'а (Mailtrap-Signature).
KKR_MAILTRAP_SIGNING_SECRET=
KKR_MAILTRAP_BASE_URL=https://mailtrap.io
# id папки inbound, внутри которой создаются личные ящики клиентов (folder_id).
KKR_MAILTRAP_INBOX_ID=0
# Проверенный адрес отправителя (From) для исходящих писем. Должен быть на домене, верифицированном
# в Mailtrap Email API -> Sending Domains; адрес inbound-ящика отправителем быть НЕ МОЖЕТ
# (Mailtrap вернёт 401 Unauthorized для неверифицированного домена отправителя).
KKR_MAILTRAP_FROM_EMAIL=

# --- Langfuse (LLM-обсервабельность; self-hosted через docker compose, UI: http://localhost:3000).
# Трейсинг ВЫКЛЮЧЕН, пока KKR_LANGFUSE_ENABLED=true И заданы оба ключа — иначе запуск без стека
# Langfuse остаётся чистым. Ключи должны совпадать с LANGFUSE_INIT_PROJECT_* из docker-compose.yml.
# Один агент-оборот = один трейс; session_id = per-client LangGraph thread (вся переписка гостя
# группируется в одну сессию в UI), user_id = id клиента.
KKR_LANGFUSE_ENABLED=false
KKR_LANGFUSE_HOST=http://localhost:3000
KKR_LANGFUSE_PUBLIC_KEY=
KKR_LANGFUSE_SECRET_KEY=

